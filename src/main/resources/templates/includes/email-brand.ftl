<#-- Raw Needed email brand styles - logo colors: #0e3651 (primary), #009aa7 (accent) -->
<style>
    body { font-family: 'Segoe UI', Tahoma, Arial, sans-serif; line-height: 1.6; color: #333; background: #f5f5f5; margin: 0; padding: 20px; }
    .container { max-width: 700px; margin: 0 auto; padding: 30px; background: #fff; border-radius: 8px; box-shadow: 0 0 20px rgba(0,0,0,0.08); }
    .logo { text-align: center; margin-bottom: 24px; }
    .logo img { max-height: 80px; }
    .section { margin-bottom: 28px; }
    .section h1, .section h2 { color: #0e3651; font-size: 20px; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #eee; }
    .section h1 { font-size: 26px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid #dee2e6; }
    .message-box { background: #f8f9fa; border-right: 4px solid #009aa7; padding: 12px 16px; margin: 12px 0; }
    .divider { border: 0; height: 1px; background: linear-gradient(to right, transparent, #dee2e6, transparent); margin: 28px 0; }
    .footer { text-align: center; font-size: 12px; color: #6c757d; margin-top: 24px; padding-top: 16px; border-top: 1px solid #eee; }
    table { border-collapse: collapse; width: 100%; font-size: 14px; margin: 12px 0; border: 1px solid #dee2e6; }
    th, td { border: 1px solid #dee2e6; padding: 10px 12px; text-align: left; }
    th { background: #0e3651; color: #fff; font-weight: 600; }
    tr:nth-child(even) { background: #f8f9fa; }
    [dir="rtl"] th, [dir="rtl"] td { text-align: right; }
    .table-container { margin: 25px 0; overflow-x: auto; box-shadow: 0 0 10px rgba(0,0,0,0.05); }
    .table-container table { margin: 0; }
    ul { list-style-type: none; padding: 0; margin: 15px 0; }
    li { padding: 8px 0; border-bottom: 1px dashed #dee2e6; }
    li:last-child { border-bottom: none; }
    [dir="rtl"] { text-align: right; }
    [dir="rtl"] li { padding-right: 10px; }
    [dir="ltr"] li { padding-left: 10px; }
    p { margin-bottom: 15px; }
</style>
